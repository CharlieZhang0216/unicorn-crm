<%- include('partials/header', { title: 'API Documentation' }) %>

<h2>API Documentation</h2>
<p class="text-muted">Unicorn CRM REST API reference for client and third-party integration.</p>

<div class="card shadow-sm mb-4">
  <div class="card-header fw-bold">Base URL</div>
  <div class="card-body">
    <code>/api/v1</code>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header fw-bold">Authentication</div>
  <div class="card-body">
    <p>API requests require a valid session token passed via the <code>Authorization</code> header or cookie:</p>
    <pre class="bg-light p-3 rounded"><code>Authorization: Bearer &lt;session_token&gt;</code></pre>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header fw-bold">Endpoints</div>
  <div class="card-body">
    <h5>GET /api/v1/users</h5>
    <p>Returns a list of users.</p>
    <table class="table table-sm table-bordered">
      <thead><tr><th>Field</th><th>Type</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td>id</td><td>integer</td><td>User ID</td></tr>
        <tr><td>username</td><td>string</td><td>Username</td></tr>
        <tr><td>email</td><td>string</td><td>Email address</td></tr>
        <tr><td>full_name</td><td>string</td><td>Display name</td></tr>
        <tr><td>department</td><td>string</td><td>Department</td></tr>
        <tr><td>role</td><td>string</td><td>User role (employee/admin)</td></tr>
      </tbody>
    </table>

    <h5>GET /api/v1/messages</h5>
    <p>Returns messages for the authenticated user.</p>

    <h5>GET /api/v1/config</h5>
    <p>Returns system configuration (public keys only).</p>
  </div>
</div>

<%- include('partials/footer') %>
