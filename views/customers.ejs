<%- include('partials/header', { title: 'Customers' }) %>

<h2>Customers</h2>
<p class="text-muted">Manage your customer accounts and relationships.</p>

<!-- Search and Filters -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/customers" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small fw-bold">Search</label>
        <input type="text" class="form-control" name="q" placeholder="Name, email, or company..." value="<%= typeof q !== 'undefined' ? q : '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-bold">Tier</label>
        <select class="form-select" name="tier">
          <option value="">All Tiers</option>
          <option value="A" <%= tier === 'A' ? 'selected' : '' %>>Tier A</option>
          <option value="B" <%= tier === 'B' ? 'selected' : '' %>>Tier B</option>
          <option value="C" <%= tier === 'C' ? 'selected' : '' %>>Tier C</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-bold">Status</label>
        <select class="form-select" name="status">
          <option value="">All Status</option>
          <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
          <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
          <option value="lead" <%= status === 'lead' ? 'selected' : '' %>>Lead</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-bold">Region</label>
        <select class="form-select" name="region">
          <option value="">All Regions</option>
          <% if (typeof regions !== 'undefined') { regions.forEach(function(r) { %>
          <option value="<%= r %>" <%= region === r ? 'selected' : '' %>><%= r %></option>
          <% }); } %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-bold">Sort</label>
        <select class="form-select" name="sort">
          <option value="company_name" <%= sort === 'company_name' ? 'selected' : '' %>>Company</option>
          <option value="tier" <%= sort === 'tier' ? 'selected' : '' %>>Tier</option>
          <option value="annual_revenue" <%= sort === 'annual_revenue' ? 'selected' : '' %>>Revenue</option>
          <option value="created_at" <%= sort === 'created_at' || sort === '' ? 'selected' : '' %>>Date</option>
        </select>
      </div>
      <div class="col-md-1">
        <label class="form-label small fw-bold">&nbsp;</label>
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
    </form>
  </div>
</div>

<!-- Results -->
<div class="card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><strong><%= total %></strong> customer<%= total !== 1 ? 's' : '' %> found</span>
    <% if (q || tier || status || region) { %>
    <a href="/customers" class="btn btn-sm btn-outline-secondary">Clear Filters</a>
    <% } %>
  </div>
  <div class="card-body p-0">
    <% if (customers.length === 0) { %>
    <div class="text-center py-5">
      <p class="text-muted mb-2 fs-4">📭</p>
      <p class="text-muted">No customers found matching your criteria.</p>
      <% if (q || tier || status || region) { %>
      <a href="/customers" class="btn btn-sm btn-outline-primary">View All Customers</a>
      <% } %>
    </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>
              <a href="/customers?sort=company_name&order=<%= sort === 'company_name' && order === 'asc' ? 'desc' : 'asc' %><%= q ? '&q=' + q : '' %><%= tier ? '&tier=' + tier : '' %><%= status ? '&status=' + status : '' %><%= region ? '&region=' + region : '' %>" class="text-decoration-none text-dark">
                Company <%= sort === 'company_name' ? (order === 'asc' ? '▲' : '▼') : '' %>
              </a>
            </th>
            <th>Contact</th>
            <th>Email</th>
            <th>Tier</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% customers.forEach(function(c) { %>
          <tr class="cursor-pointer" onclick="window.location.href='/customers/<%= c.id %>'" style="cursor: pointer;">
            <td><strong><%= c.company_name %></strong></td>
            <td><%= c.contact_name %></td>
            <td><small><%= c.email || '—' %></small></td>
            <td>
              <span class="badge <%= c.tier === 'A' ? 'bg-success' : c.tier === 'B' ? 'bg-primary' : 'bg-secondary' %>"><%= c.tier %></span>
            </td>
            <td>
              <span class="badge <%= c.status === 'active' ? 'bg-success' : c.status === 'inactive' ? 'bg-danger' : 'bg-warning text-dark' %>"><%= c.status %></span>
            </td>
            <td>
              <a href="/customers/<%= c.id %>" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();">View</a>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="card-footer">
    <nav>
      <ul class="pagination pagination-sm justify-content-center mb-0">
        <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="/customers?page=<%= page - 1 %>&limit=<%= limit %><%= q ? '&q=' + q : '' %><%= tier ? '&tier=' + tier : '' %><%= status ? '&status=' + status : '' %><%= region ? '&region=' + region : '' %><%= '&sort=' + sort + '&order=' + order %>">&laquo; Prev</a>
        </li>
        <% var startPage = Math.max(1, page - 2); var endPage = Math.min(totalPages, page + 2); %>
        <% for (var i = startPage; i <= endPage; i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="/customers?page=<%= i %>&limit=<%= limit %><%= q ? '&q=' + q : '' %><%= tier ? '&tier=' + tier : '' %><%= status ? '&status=' + status : '' %><%= region ? '&region=' + region : '' %><%= '&sort=' + sort + '&order=' + order %>"><%= i %></a>
        </li>
        <% } %>
        <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="/customers?page=<%= page + 1 %>&limit=<%= limit %><%= q ? '&q=' + q : '' %><%= tier ? '&tier=' + tier : '' %><%= status ? '&status=' + status : '' %><%= region ? '&region=' + region : '' %><%= '&sort=' + sort + '&order=' + order %>">Next &raquo;</a>
        </li>
      </ul>
    </nav>
    <p class="text-center text-muted small mb-0 mt-1">Page <%= page %> of <%= totalPages %> (<%= total %> total)</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
