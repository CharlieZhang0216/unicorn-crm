<%- include('partials/header') %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Notifications <span class="badge bg-danger ms-2"><%= unreadCount || 0 %> unread</span></h2>
    <% if (unreadCount > 0) { %>
    <button class="btn btn-outline-primary btn-sm" onclick="markAllRead()">
      Mark All Read
    </button>
    <% } %>
  </div>

  <% if (notifications.length === 0) { %>
  <div class="alert alert-info">No notifications yet.</div>
  <% } else { %>

  <div class="list-group">
    <% notifications.forEach(n => { %>
    <div class="list-group-item list-group-item-action <%= n.is_read ? '' : 'list-group-item-warning' %>">
      <div class="d-flex w-100 justify-content-between">
        <h6 class="mb-1">
          <% if (!n.is_read) { %><span class="badge bg-primary me-1">NEW</span><% } %>
          <span class="text-uppercase small text-muted">[<%= n.type %>]</span>
          <%= n.title %>
        </h6>
        <small class="text-muted"><%= n.created_at %></small>
      </div>
      <% if (n.body) { %>
      <p class="mb-1"><%= n.body %></p>
      <% } %>
      <div class="d-flex justify-content-between align-items-center">
        <small class="text-muted">
          <% if (n.entity_type) { %>
          Entity: <%= n.entity_type %><%= n.entity_id ? ' #' + n.entity_id : '' %>
          <% } %>
        </small>
        <% if (!n.is_read) { %>
        <button class="btn btn-sm btn-outline-secondary" onclick="markRead(<%= n.id %>)">Mark Read</button>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= page - 1 %>">Previous</a>
      </li>
      <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= i === page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
      </li>
      <% } %>
      <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= page + 1 %>">Next</a>
      </li>
    </ul>
  </nav>
  <% } %>

  <% } %>
</div>

<script>
function markRead(id) {
  fetch('/notifications/' + id + '/read', { method: 'PUT', headers: { 'Accept': 'application/json' } })
    .then(r => r.json())
    .then(data => {
      if (data.success) location.reload();
    });
}
function markAllRead() {
  fetch('/notifications/read-all', { method: 'PUT', headers: { 'Accept': 'application/json' } })
    .then(r => r.json())
    .then(data => {
      if (data.success) location.reload();
    });
}
</script>
<%- include('partials/footer') %>
