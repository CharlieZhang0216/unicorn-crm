<%- include('../partials/header', { title: 'API Tokens - Unicorn CRM' }) %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>API Tokens</h2>
    <button class="btn btn-primary" onclick="createToken()">Generate New Token</button>
  </div>
  
  <div class="card">
    <div class="card-body">
      <p class="text-muted">Manage your API access tokens for programmatic access to Unicorn CRM.</p>
      <% if (tokens && tokens.length > 0) { %>
      <table class="table">
        <thead><tr><th>Name</th><th>Created</th><th>Expires</th><th>Last Used</th><th>Actions</th></tr></thead>
        <tbody>
        <% tokens.forEach(t => { %>
          <tr>
            <td><%= t.name %></td>
            <td><%= new Date(t.created_at).toLocaleDateString() %></td>
            <td><%= t.expires_at ? new Date(t.expires_at).toLocaleDateString() : 'Never' %></td>
            <td><%= t.last_used_at ? new Date(t.last_used_at).toLocaleString() : 'Never' %></td>
            <td><button class="btn btn-sm btn-danger" onclick="revokeToken('<%= t.id %>')">Revoke</button></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <p class="text-muted">No API tokens yet.</p>
      <% } %>
    </div>
  </div>
</div>
<script>
function createToken() {
  const name = prompt("Token name:");
  if (!name) return;
  fetch("/api-tokens", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ name })
  }).then(r => r.json()).then(data => {
    if (data.token) {
      alert("New token (save it - won\\'t be shown again):\\n\\n" + data.token);
    }
    location.reload();
  }).catch(e => alert("Error: " + e));
}
function revokeToken(id) {
  if (!confirm("Revoke this token?")) return;
  fetch("/api-tokens/" + id + "/revoke", { method: "POST" })
    .then(() => location.reload());
}
</script>
<%- include('../partials/footer') %>
