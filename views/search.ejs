<%- include('partials/header', { title: 'Global Search' }) %>

<h2>Global Search</h2>
<p class="text-muted">Search across customers, orders, and support tickets.</p>

<!-- Search Form -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <form action="/search" method="GET">
      <div class="input-group input-group-lg">
        <input type="text" class="form-control" name="q" placeholder="Search by company, contact name, order ref, or ticket subject..." value="<%= typeof q !== 'undefined' ? q : '' %>" autofocus>
        <button type="submit" class="btn btn-primary px-4">Search</button>
        <% if (q) { %>
        <a href="/search" class="btn btn-outline-secondary">Clear</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<!-- Results -->
<% if (typeof results !== 'undefined' && results !== null) { %>
<div class="card shadow-sm">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span>
      Results for "<strong><%= query %></strong>"
      <span class="badge bg-secondary ms-2"><%= total %> found</span>
    </span>
    <% if (q) { %>
    <a href="/search" class="btn btn-sm btn-outline-secondary">New Search</a>
    <% } %>
  </div>
  <div class="card-body p-0">
    <% if (results.length === 0) { %>
    <div class="text-center py-5">
      <p class="text-muted mb-2 fs-4">🔍</p>
      <p class="text-muted">No results found for "<strong><%= query %></strong>".</p>
      <p class="text-muted small">Try a different keyword or check your spelling.</p>
    </div>
    <% } else { %>
    <div class="list-group list-group-flush">
      <% results.forEach(function(r) { %>
      <% if (r.result_type === 'customer') { %>
      <a href="/customers/<%= r.id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <span class="badge bg-primary me-2">Customer</span>
            <strong><%= r.company_name %></strong>
            <small class="text-muted ms-2"><%= r.contact_name %></small>
          </div>
          <div class="text-end">
            <span class="badge <%= r.tier === 'A' ? 'bg-success' : r.tier === 'B' ? 'bg-primary' : 'bg-secondary' %> me-1"><%= r.tier %></span>
            <span class="badge <%= r.status === 'active' ? 'bg-success' : r.status === 'inactive' ? 'bg-danger' : 'bg-warning text-dark' %>"><%= r.status %></span>
          </div>
        </div>
        <% if (r.email) { %><small class="text-muted"><%= r.email %></small><% } %>
      </a>
      <% } else if (r.result_type === 'order') { %>
      <a href="/orders/<%= r.id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <span class="badge bg-info me-2">Order</span>
            <strong><code><%= r.order_ref %></code></strong>
            <small class="text-muted ms-2"><%= r.customer_name %></small>
          </div>
          <div class="text-end">
            <span class="text-nowrap me-2">$<%= r.total ? r.total.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '0.00' %></span>
            <span class="badge <%= r.status === 'approved' ? 'bg-success' : r.status === 'pending' ? 'bg-warning text-dark' : r.status === 'rejected' ? 'bg-danger' : 'bg-secondary' %>"><%= r.status %></span>
          </div>
        </div>
        <small class="text-muted"><%= r.created_at %></small>
      </a>
      <% } else if (r.result_type === 'ticket') { %>
      <a href="/tickets/<%= r.id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <span class="badge bg-warning text-dark me-2">Ticket</span>
            <strong><small><code><%= r.ticket_ref %></code></small>: <%= r.subject %></strong>
          </div>
          <div>
            <span class="badge <%= r.priority === 'Critical' || r.priority === 'High' ? 'bg-danger' : r.priority === 'Medium' ? 'bg-warning text-dark' : 'bg-info text-dark' %> me-1"><%= r.priority %></span>
            <span class="badge <%= r.status === 'open' ? 'bg-danger' : r.status === 'in_progress' ? 'bg-warning text-dark' : r.status === 'resolved' ? 'bg-success' : 'bg-secondary' %>"><%= r.status.replace('_', ' ') %></span>
          </div>
        </div>
        <small class="text-muted"><%= r.created_at %></small>
      </a>
      <% } %>
      <% }); %>
    </div>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="card-footer">
    <nav>
      <ul class="pagination pagination-sm justify-content-center mb-0">
        <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="/search?q=<%= query %>&page=<%= page - 1 %>&limit=<%= limit %>">&laquo; Prev</a>
        </li>
        <% var startPage = Math.max(1, page - 2); var endPage = Math.min(totalPages, page + 2); %>
        <% for (var i = startPage; i <= endPage; i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="/search?q=<%= query %>&page=<%= i %>&limit=<%= limit %>"><%= i %></a>
        </li>
        <% } %>
        <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="/search?q=<%= query %>&page=<%= page + 1 %>&limit=<%= limit %>">Next &raquo;</a>
        </li>
      </ul>
    </nav>
    <p class="text-center text-muted small mb-0 mt-1">Page <%= page %> of <%= totalPages %></p>
  </div>
  <% } %>
</div>
<% } else { %>
<!-- No search yet — show a placeholder -->
<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <p class="text-muted mb-2 fs-1">🔍</p>
    <p class="text-muted fs-5">Enter a keyword above to search</p>
    <p class="text-muted small">Search across customers, orders, and support tickets.</p>
  </div>
</div>
<% } %>

<%- include('partials/footer') %>
